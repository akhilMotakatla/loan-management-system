NODE_ENV=development
PORT=5000

# SQLite — file lives at server/database.sqlite (auto-created on first run)
# No configuration needed for the database itself

# JWT — generate 64-char random strings
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_here_change_this
JWT_REFRESH_SECRET=your_different_refresh_secret_min_64_chars_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (optional — leave blank to disable email notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# CORS
CLIENT_URL=http://localhost:5173
