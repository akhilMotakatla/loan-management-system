NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/loandb

# JWT — generate 64-char random strings
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_here_change_this
JWT_REFRESH_SECRET=your_different_refresh_secret_min_64_chars_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (cloudinary.com — free tier)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis (local: redis://localhost:6379 | cloud Upstash URL)
REDIS_URL=redis://localhost:6379

# Email (Gmail App Password recommended)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# CORS
CLIENT_URL=http://localhost:5173
